---
import BaseLayout from '../layouts/BaseLayout.astro';

const submitted = Astro.url.searchParams.get('sent') === '1';
const errored = Astro.url.searchParams.get('err');
---
<BaseLayout
  title="Contact | Arclight Advisory"
  description="Start a conversation with Arclight Advisory. Email hello@arclight.example or use the form to tell us about your decision."
>
  <section class="bg-navy-900 text-white">
    <div class="container-prose py-24">
      <p class="eyebrow mb-4">Contact</p>
      <h1 class="font-serif text-5xl md:text-6xl max-w-3xl">Tell us what you're wrestling with.</h1>
      <p class="mt-6 max-w-2xl text-navy-200 leading-relaxed text-lg">
        We reply within one business day. For press and speaking requests, email us directly at <a href="mailto:hello@arclight.example" class="text-gold-500 underline underline-offset-4">hello@arclight.example</a>.
      </p>
    </div>
  </section>

  <section class="py-24">
    <div class="container-prose grid md:grid-cols-5 gap-12">
      <aside class="md:col-span-2">
        <h2 class="font-serif text-2xl text-navy-900 mb-5">Offices</h2>
        <div class="space-y-6 text-navy-700">
          <div>
            <p class="text-gold-600 text-xs tracking-widest uppercase mb-1">London</p>
            <p>22 Bedford Square<br />Bloomsbury, WC1B 3HH</p>
          </div>
          <div>
            <p class="text-gold-600 text-xs tracking-widest uppercase mb-1">New York</p>
            <p>71 Fifth Avenue, 8th Floor<br />New York, NY 10003</p>
          </div>
          <div class="pt-4 border-t hairline">
            <p class="text-gold-600 text-xs tracking-widest uppercase mb-1">General</p>
            <p><a href="mailto:hello@arclight.example" class="hover:text-gold-600">hello@arclight.example</a></p>
          </div>
        </div>
      </aside>

      <div class="md:col-span-3">
        {submitted && (
          <div class="mb-8 border border-gold-500 bg-gold-50 text-navy-900 p-5">
            <p class="font-serif text-lg">Thank you — message received.</p>
            <p class="text-sm mt-1">A partner will be in touch within one business day.</p>
          </div>
        )}
        {errored && (
          <div class="mb-8 border border-red-400 bg-red-50 text-red-900 p-5">
            <p class="font-serif text-lg">Something went wrong.</p>
            <p class="text-sm mt-1">Please try again or email us directly at hello@arclight.example.</p>
          </div>
        )}

        <form method="POST" action="/api/contact" class="space-y-6">
          <div class="grid md:grid-cols-2 gap-6">
            <label class="block">
              <span class="block text-xs tracking-widest uppercase text-navy-700 mb-2">Name</span>
              <input required name="name" type="text" class="w-full border hairline bg-white p-3 focus:outline-none focus:border-gold-500" />
            </label>
            <label class="block">
              <span class="block text-xs tracking-widest uppercase text-navy-700 mb-2">Email</span>
              <input required name="email" type="email" class="w-full border hairline bg-white p-3 focus:outline-none focus:border-gold-500" />
            </label>
          </div>
          <label class="block">
            <span class="block text-xs tracking-widest uppercase text-navy-700 mb-2">Company</span>
            <input name="company" type="text" class="w-full border hairline bg-white p-3 focus:outline-none focus:border-gold-500" />
          </label>
          <label class="block">
            <span class="block text-xs tracking-widest uppercase text-navy-700 mb-2">What are you working on?</span>
            <textarea required name="message" rows="6" class="w-full border hairline bg-white p-3 focus:outline-none focus:border-gold-500"></textarea>
          </label>
          <button type="submit" class="btn-gold">Send message</button>
          <p class="text-xs text-navy-500">We respect your privacy. Your message goes to the principals only.</p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>
